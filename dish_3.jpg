}
.badge-preorder {
  background: linear-gradient(135deg,#f77f00,#faa307) !important;
}

.btn-card {
  background: linear-gradient(135deg,#00b4d8,#071e3d) !important;
  box-shadow: 0 4px 14px rgba(0,119,182,.25) !important;
}
.btn-card:hover { opacity:.88; transform:translateY(-1px); }

/* Filter Tabs */
.filter-tab {
  border-color: rgba(0,180,216,.35) !important;
  color: #0077b6 !important;
}
.filter-tab.active, .filter-tab:hover {
  background: linear-gradient(135deg,#00b4d8,#0077b6) !important;
  border-color: #00b4d8 !important;
